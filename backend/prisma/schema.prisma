generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum SubscriptionStatus {
  FREE
  MONTHLY
  YEARLY
  LIFETIME
}

enum PlanType {
  MONTHLY
  YEARLY
  LIFETIME
}

enum PaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
  REFUNDED
}

enum QuizAttemptStatus {
  IN_PROGRESS
  COMPLETED
}

model User {
  id                String             @id @default(cuid())
  email             String             @unique
  passwordHash      String?
  name              String?
  avatar            String?
  googleId          String?            @unique
  lsCustomerId          String?            @unique
  lsSubscriptionId      String?            @unique
  subscriptionStatus    SubscriptionStatus @default(FREE)
  subscriptionEnd       DateTime?
  streakCount          Int                @default(0)
  lastActiveDate       DateTime?
  preferredCategories  String[]
  createdAt            DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  progress          UserProgress[]
  reflections       Reflection[]
  highlights        Highlight[]
  favorites         Favorite[]
  quizAttempts      QuizAttempt[]
  actionPlans       ActionPlan[]
  payments          Payment[]
  reviews           Review[]
}

model Module {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  description String
  category    String
  content     String
  isPremium   Boolean  @default(true)
  isDraft     Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  nodes           ModuleNode[]
  edges           ModuleEdge[]
  questions       Question[]
  progress        UserProgress[]
  reflections     Reflection[]
  highlights      Highlight[]
  favorites       Favorite[]
  quizAttempts    QuizAttempt[]
  actionPlans     ActionPlan[]
  reviews         Review[]
}

model ModuleNode {
  id        String @id @default(cuid())
  moduleId  String
  positionX Float
  positionY Float
  label     String
  description String?
  type      String @default("custom")
  style     Json?

  module Module @relation(fields: [moduleId], references: [id], onDelete: Cascade)
}

model ModuleEdge {
  id       String  @id @default(cuid())
  moduleId String
  source   String
  target   String
  label    String?
  animated Boolean @default(true)

  module Module @relation(fields: [moduleId], references: [id], onDelete: Cascade)
}

model Question {
  id             String @id @default(cuid())
  moduleId       String
  question       String
  options        Json
  correctAnswer  Int
  explanation    String

  module Module @relation(fields: [moduleId], references: [id], onDelete: Cascade)
}

model UserProgress {
  id                String   @id @default(cuid())
  userId            String
  moduleId          String
  listeningProgress Float    @default(0)
  readingProgress   Float    @default(0)
  scrollPosition    Float    @default(0)
  currentCharIndex  Int      @default(0)
  audioRate         Float    @default(1)
  completed         Boolean  @default(false)
  lastReadAt        DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  module Module @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@unique([userId, moduleId])
}

model Reflection {
  id          String   @id @default(cuid())
  userId      String
  moduleId    String
  title       String
  content     String
  timestamp   DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  module Module @relation(fields: [moduleId], references: [id], onDelete: Cascade)
}

model Highlight {
  id        String @id @default(cuid())
  userId    String
  moduleId  String
  text      String
  note      String  @default("")
  timestamp DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  module Module @relation(fields: [moduleId], references: [id], onDelete: Cascade)
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  moduleId  String
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  module Module @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@unique([userId, moduleId])
}

model QuizAttempt {
  id              String            @id @default(cuid())
  userId          String
  moduleId        String
  score           Int               @default(0)
  totalQuestions  Int               @default(0)
  percentage      Float             @default(0)
  status          QuizAttemptStatus @default(IN_PROGRESS)
  answers         Json?
  currentQuestion Int?
  completedAt     DateTime          @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  module Module @relation(fields: [moduleId], references: [id], onDelete: Cascade)
}

model ActionPlan {
  id        String   @id @default(cuid())
  userId    String
  moduleId  String
  title     String
  content   Json
  appliedAt DateTime @default(now())
  completed Boolean  @default(false)

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  module Module @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@unique([userId, moduleId])
}

model Review {
  id        String   @id @default(cuid())
  userId    String
  moduleId  String?
  rating    Int
  comment   String   @default("")
  createdAt DateTime @default(now())

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  module Module? @relation(fields: [moduleId], references: [id], onDelete: SetNull)
}

model SubscriptionPlan {
  id        String   @id @default(cuid())
  planType  PlanType @unique
  name      String
  slug      String   @unique
  description String
  price     Int      // in cents
  features  String[] // feature list
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model LemonSqueezyEvent {
  id        String   @id
  type      String
  processed Boolean  @default(false)
  payload   Json
  createdAt DateTime @default(now())
  processedAt DateTime?
}

model Payment {
  id               String        @id @default(cuid())
  userId           String
  lsOrderId        String        @unique
  lsSubscriptionId String?
  amount           Int
  currency         String        @default("usd")
  status           PaymentStatus @default(PENDING)
  planType         PlanType
  createdAt        DateTime      @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
